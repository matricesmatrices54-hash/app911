{
  "name": "app911",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "postexport:web": "node scripts/prepare-gh-pages.js",
    "build:gh-pages": "npm run export:web",
    "deploy": "npm run build:gh-pages && gh-pages -d dist"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~55.0.7",
    "expo-image-picker": "^55.0.13",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  },
  "private": true
}
